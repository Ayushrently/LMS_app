<div class="auth_page">
  <div class="auth_card">
    <h1 class="auth_title">Create account</h1>
    <p class="auth_subtitle">Set up your learner account and continue.</p>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "app_form mt-0" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :email %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email" %>
      </div>

      <div>
        <%= f.label :password %>
        <% if @minimum_password_length %>
          <small class="text-muted d-block mb-1">Minimum <%= @minimum_password_length %> characters</small>
        <% end %>
        <%= f.password_field :password, autocomplete: "new-password" %>
      </div>

      <div>
        <%= f.label :password_confirmation %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password" %>
      </div>

      <div class="auth_actions">
        <%= f.submit "Create account" %>
      </div>
    <% end %>

    <div class="auth_links">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
