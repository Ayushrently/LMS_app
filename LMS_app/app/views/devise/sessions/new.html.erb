<div class="auth_page lms-course-shell py-4 py-md-5">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-12 col-md-10 col-lg-7 col-xl-5">
        <section class="auth_card card border-0 shadow-sm">
          <div class="card-body p-4 p-md-5">
            <p class="text-uppercase small fw-semibold text-secondary mb-2">Welcome Back</p>
            <h1 class="auth_title h3 mb-2">Sign in</h1>
            <p class="auth_subtitle text-body-secondary mb-4">Access your courses, workspace, and profile.</p>

            <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "app_form mt-0" }) do |f| %>
              <%= render "devise/shared/error_messages", resource: resource %>

              <div class="mb-4">
                <%= f.label :email, class: "form-label" %>
                <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control" %>
              </div>

              <div class="mb-4">
                <%= f.label :password, class: "form-label" %>
                <%= f.password_field :password, autocomplete: "current-password", class: "form-control" %>
              </div>

              <% if devise_mapping.rememberable? %>
                <div class="form-check mb-4">
                  <%= f.check_box :remember_me, class: "form-check-input" %>
                  <%= f.label :remember_me, class: "form-check-label" %>
                </div>
              <% end %>

              <div class="auth_actions d-grid gap-2">
                <%= f.submit "Sign in", class: "btn btn-primary btn-lg" %>
              </div>
            <% end %>

            <div class="auth_links pt-4 mt-4 border-top">
              <%= render "devise/shared/links" %>
            </div>
          </div>
        </section>
      </div>
    </div>
  </div>
</div>
