<div class="course-workspace-page lms-course-shell py-4 py-md-5">
  <div class="container">
    <%= render "navbar/navbar",
                nav_heading: "Account",
                nav_title: "User Details",
                nav_text: "Manage account and profile information.",
                nav_links: [
                  { text: "Courses", path: courses_path }
                ] %>

    <section class="card border-0 shadow-sm">
      <div class="card-header bg-white border-0 pt-3 pb-0 px-3 px-md-4">
        <h2 class="h5 mb-1">Account Summary</h2>
        <p class="text-body-secondary mb-3">Current account information and profile actions.</p>
      </div>
      <div class="card-body pt-0 p-3 p-md-4">
        <dl class="row mb-4">
          <dt class="col-sm-3 text-body-secondary">Email</dt>
          <dd class="col-sm-9"><%= @user.email %></dd>

          <dt class="col-sm-3 text-body-secondary">Role</dt>
          <dd class="col-sm-9 mb-0"><%= @user.role %></dd>
        </dl>

        <% if @user.profile.present? %>
          <h3 class="h6 mb-3">Profile</h3>
          <dl class="row mb-4">
            <dt class="col-sm-3 text-body-secondary">Name</dt>
            <dd class="col-sm-9"><%= @user.profile.name %></dd>

            <dt class="col-sm-3 text-body-secondary">Username</dt>
            <dd class="col-sm-9 mb-0"><%= @user.profile.username %></dd>
          </dl>

          <% if @user.subscription.present? %>
            <h3 class="h6 mb-2">Subscription</h3>
            <p class="mb-4"><span class="text-body-secondary me-2">Plan:</span><span class="fw-semibold"><%= @user.subscription.plan_name %></span></p>
          <% end %>

          <div class="d-flex flex-column flex-sm-row gap-2">
            <%= link_to "View profile", user_profile_path(@user), class: "btn btn-outline-secondary" %>
            <%= link_to "Edit profile", edit_user_profile_path(@user), class: "btn btn-primary" %>
          </div>
        <% else %>
          <%= link_to "Complete profile", new_user_profile_path(@user), class: "btn btn-primary" %>
        <% end %>
      </div>
    </section>
  </div>
</div>