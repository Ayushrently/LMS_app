<div class="course-workspace-page py-4 py-md-5">
  <div class="container">
    <section class="workspace-hero card border-0 shadow-sm mb-4">
      <div class="card-body p-3 p-md-4">
        <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
          <div>
            <p class="text-uppercase small fw-semibold text-secondary mb-1">Profile</p>
            <h1 class="h3 mb-1"><%= @profile.name.presence || "User Profile" %></h1>
            <p class="text-body-secondary mb-0">@<%= @profile.username %></p>
          </div>
          <div class="d-flex flex-wrap gap-2">
            <%= link_to "Edit profile", edit_user_profile_path(@user), class: "btn btn-primary btn-sm" %>
            <%= link_to "Courses", courses_path, class: "btn btn-outline-secondary btn-sm" %>
            <% if current_user.present? %>
              <%= link_to "Profile", user_profile_path(current_user), class: "btn btn-outline-dark btn-sm" %>
              <%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete }, class: "btn btn-dark btn-sm" %>
            <% else %>
              <%= link_to "Sign in", new_user_session_path, class: "btn btn-dark btn-sm" %>
            <% end %>
          </div>
        </div>
      </div>
    </section>

    <section class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white border-0 pt-3 pb-0 px-3 px-md-4">
        <h2 class="h5 mb-1">Profile Details</h2>
        <p class="text-body-secondary mb-3">Personal information</p>
      </div>
      <div class="card-body pt-0 p-3 p-md-4">
        <dl class="row mb-0">
          <dt class="col-sm-3 text-body-secondary">Name</dt>
          <dd class="col-sm-9"><%= @profile.name %></dd>

          <dt class="col-sm-3 text-body-secondary">Username</dt>
          <dd class="col-sm-9"><%= @profile.username %></dd>

          <dt class="col-sm-3 text-body-secondary">Bio</dt>
          <dd class="col-sm-9 mb-0"><%= @profile.bio %></dd>
        </dl>
      </div>
    </section>

    <% if @profile.subscription.present? %>
      <section class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0 pt-3 pb-0 px-3 px-md-4">
          <h2 class="h5 mb-1">Subscription</h2>
          <p class="text-body-secondary mb-3">Current plan</p>
        </div>
        <div class="card-body pt-0 p-3 p-md-4">
          <p class="mb-0"><span class="text-body-secondary me-2">Plan:</span><span class="fw-semibold"><%= @profile.subscription.plan_name %></span></p>
        </div>
      </section>
    <% end %>
  </div>
</div>
