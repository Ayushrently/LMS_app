<div class="app-page py-4 py-md-5">
  <div class="container">
    <section class="workspace-hero card border-0 shadow-sm mb-4">
      <div class="card-body p-3 p-md-4">
        <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
          <div>
            <p class="text-uppercase small fw-semibold text-secondary mb-1">Learning Hub</p>
            <h1 class="h3 mb-1">Courses</h1>
            <p class="text-body-secondary mb-0">Browse your enrolled courses and discover new ones.</p>
          </div>
          <div class="d-flex flex-wrap gap-2">
            <%= link_to "Create New Course", new_course_path, class: "btn btn-primary btn-sm" %>
            <% if current_user_author? %>
              <%= link_to "Workspace", workspace_path, class: "btn btn-outline-secondary btn-sm" %>
            <% end %>
            <% if current_user.present? %>
              <%= link_to "Profile", user_profile_path(current_user), class: "btn btn-outline-dark btn-sm" %>
              <%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete }, class: "btn btn-dark btn-sm" %>
            <% else %>
              <%= link_to "Sign in", new_user_session_path, class: "btn btn-dark btn-sm" %>
            <% end %>
          </div>
        </div>
      </div>
    </section>

    <section class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white border-0 pt-3 pb-0 px-3 px-md-4">
        <h2 class="h5 mb-1">Enrolled Courses</h2>
        <p class="text-body-secondary mb-3">Continue learning from the courses you have joined.</p>
      </div>
      <div class="card-body pt-0 p-3 p-md-4">
        <% if @enrolled_courses.any? %>
          <div class="row g-3 g-md-4">
            <% @enrolled_courses.each do |course| %>
              <div class="col-12 col-md-6 col-xl-4">
                <article class="course-list-card card h-100 border-0 shadow-sm">
                  <div class="card-body d-flex flex-column">
                    <h3 class="h6 mb-2"><%= link_to course.title, course_path(course.id), class: "text-decoration-none text-dark" %></h3>
                    <p class="small text-body-secondary mb-0">Creator: <%= course.creator %></p>
                  </div>
                </article>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="rounded-3 border border-secondary-subtle bg-light p-4 text-center">
            <p class="mb-0 text-body-secondary">No enrolled courses yet.</p>
          </div>
        <% end %>
      </div>
    </section>

    <section class="card border-0 shadow-sm">
      <div class="card-header bg-white border-0 pt-3 pb-0 px-3 px-md-4">
        <h2 class="h5 mb-1">Explore Other Courses</h2>
        <p class="text-body-secondary mb-3">Find more courses available to you.</p>
      </div>
      <div class="card-body pt-0 p-3 p-md-4">
        <% if @other_courses.any? %>
          <div class="row g-3 g-md-4">
            <% @other_courses.each do |course| %>
              <div class="col-12 col-md-6 col-xl-4">
                <article class="course-list-card card h-100 border-0 shadow-sm">
                  <div class="card-body d-flex flex-column">
                    <h3 class="h6 mb-2"><%= link_to course.title, course_path(course.id), class: "text-decoration-none text-dark" %></h3>
                    <p class="small text-body-secondary mb-0">Creator: <%= course.creator %></p>
                  </div>
                </article>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="rounded-3 border border-secondary-subtle bg-light p-4 text-center">
            <p class="mb-0 text-body-secondary">No courses found.</p>
          </div>
        <% end %>
      </div>
    </section>
  </div>
</div>
