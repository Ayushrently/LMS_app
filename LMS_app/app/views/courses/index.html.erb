<div class="lms-course-shell courses-index py-4 py-md-5">
  <div class="container">
    <% temp_nav_links = [
      { text: "Create New Course", path: new_course_path, primary: false }
    ] %>
    <% if current_user_author? %>
      <% temp_nav_links.push({ text: "Workspace", path: workspace_path, primary: false }) %>
    <% end %>
    <%= render "navbar/navbar",
        nav_heading:"Learning Hub", 
        nav_title:"Courses",
        nav_text:"Browse your enrolled courses and discover new ones.", 
        nav_links:temp_nav_links
    %>

    <section class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white border-0 pt-3 pb-0 px-3 px-md-4">
        <h2 class="h5 mb-1">Enrolled Courses</h2>
        <p class="text-body-secondary mb-3">Continue learning from the courses you have joined.</p>
      </div>
      <div class="card-body pt-0 p-3 p-md-4">
        <% if @enrolled_courses.any? %>
          <div class="row g-3 g-md-4">
            <% @enrolled_courses.each do |course| %>
              <div class="col-12 col-md-6 col-xl-4">
                <article class="course-list-card card h-100 border-0">
                  <div class="card-body d-flex flex-column">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                      <h3 class="mb-0"><%= link_to course.title, course_path(course.id), class: "text-decoration-none lms-card-title-link" %></h3>
                      <span class="badge <%= course.pro? ? 'bg-info' : 'bg-success' %> ms-2 flex-shrink-0"><%= course.tier.capitalize %></span>
                    </div>
                    <p class="small text-body-secondary mb-0">Creator: <%= course.creator %></p>
                    <% if course.soft_deleted? %>
                      <span class="badge bg-warning text-dark mt-2">This course has been removed.</span>
                    <% end %>
                  </div>
                </article>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="rounded-3 border border-secondary-subtle bg-light p-4 text-center">
            <p class="mb-0 text-body-secondary">No enrolled courses yet.</p>
          </div>
        <% end %>
      </div>
    </section>

    <section class="card border-0 shadow-sm">
      <div class="card-header bg-white border-0 pt-3 pb-0 px-3 px-md-4">
        <h2 class="h5 mb-1">Explore Other Courses</h2>
        <p class="text-body-secondary mb-3">Find more courses available to you.</p>
      </div>
      <div class="card-body pt-0 p-3 p-md-4">
        <% if @other_courses.any? %>
          <div class="row g-3 g-md-4">
            <% @other_courses.each do |course| %>
              <div class="col-12 col-md-6 col-xl-4">
                <article class="course-list-card card h-100 border-0">
                  <div class="card-body d-flex flex-column">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                      <h3 class="mb-0"><%= link_to course.title, course_path(course.id), class: "text-decoration-none lms-card-title-link" %></h3>
                      <span class="badge <%= course.pro? ? 'bg-info' : 'bg-success' %> text-dark ms-2 flex-shrink-0"><%= course.tier.capitalize %></span>
                    </div>
                    <p class="small text-body-secondary mb-0">Creator: <%= course.creator %></p>
                  </div>
                </article>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="rounded-3 border border-secondary-subtle bg-light p-4 text-center">
            <p class="mb-0 text-body-secondary">No courses found.</p>
          </div>
        <% end %>
      </div>
    </section>
  </div>
</div>
