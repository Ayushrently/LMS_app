<div class="course-workspace-page lms-course-shell py-4 py-md-5">
  <div class="container">
    <%= render "navbar/navbar",
        nav_heading: "Author Area",
        nav_title: "Workspace",
        nav_text: "Manage your courses and continue editing content.",
        nav_links: [
          { text: "Back to Courses", path: courses_path, primary: false }
        ]
    %>

    <section class="card border-0 shadow-sm">
      <div class="card-header bg-white border-0 pt-3 pb-0 px-3 px-md-4">
        <h2 class="h5 mb-1">Your Courses</h2>
        <p class="text-body-secondary mb-3">Open any course to update lessons, details, and collaborators.</p>
      </div>

      <div class="card-body pt-0 p-3 p-md-4">
        <% if @courses.any? %>
          <div class="row g-3 g-md-4">
            <% @courses.each do |course| %>
              <div class="col-12 col-md-6 col-xl-4">
                <article class="course-list-card card h-100 border-0 shadow-sm">
                  <div class="card-body d-flex flex-column">
                    <h3 class="h6 mb-2"><%= link_to course.title, edit_course_path(course), class: "text-decoration-none lms-card-title-link" %></h3>
                    <p class="small text-body-secondary mb-3"><%= truncate(course.description.to_s, length: 110) %></p>
                    <div class="mt-auto pt-2 d-flex gap-2">
                      <%= button_to "Edit", edit_course_path(course), method: :get, class: "btn btn-sm btn-primary" %>
                    </div>
                  </div>
                </article>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="rounded-3 border border-secondary-subtle bg-light p-4 text-center">
            <p class="mb-1 fw-semibold">No courses yet</p>
            <p class="text-body-secondary mb-0">Create a new course from the courses page to get started.</p>
          </div>
        <% end %>
      </div>
    </section>
  </div>
</div>
