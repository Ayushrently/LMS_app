<div class="course-edit-page lms-course-shell py-4 py-md-5">
  <div class="container">
    <%= render "navbar/navbar",
        nav_heading: "Course Editor",
        nav_title: "Edit Course",
        nav_text: "Creator: #{@course.creator}",
        nav_links: [
          { text: "View Course", path: course_path(@course), primary: false },
          { text: "Back to Courses", path: courses_path, primary: false },
          { text: "Add Lesson", path: new_course_lesson_path(@course), primary: false }
        ]
    %>

    <section class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white border-0 pt-3 pb-0 px-3 px-md-4">
        <h2 class="h5 mb-1">Collaborators</h2>
        <p class="text-body-secondary mb-3">Set the usernames allowed to edit this course.</p>
      </div>
      <div class="card-body pt-0 p-3 p-md-4">
        <% if flash[:authors_alert].present? %>
          <div class="alert alert-danger mb-3" role="alert"><%= flash[:authors_alert] %></div>
        <% elsif flash[:authors_notice].present? %>
          <div class="alert alert-info mb-3" role="alert"><%= flash[:authors_notice] %></div>
        <% end %>

        <%= form_with url: update_authors_course_path(@course), method: :patch, html: { class: "authors_form row g-3 align-items-end" } do |form| %>
          <div class="col-12 col-lg-9">
            <%= form.label :authors_csv, "Authors (CSV usernames)", class: "form-label" %>
            <%= form.text_field :authors_csv, value: @authors_csv, id: "authors_csv_input", placeholder: "creator_username,another_author", class: "form-control" %>
          </div>
          <div class="col-12 col-lg-3 d-grid">
            <%= form.submit "Update Authors", class: "btn btn-outline-primary" %>
          </div>
        <% end %>
      </div>
    </section>

    <section class="card border-0 shadow-sm">
      <div class="card-header bg-white border-0 pt-3 pb-0 px-3 px-md-4">
        <h2 class="h5 mb-1">Course Details</h2>
        <p class="text-body-secondary mb-3">Update title, description, and access tier.</p>
      </div>
      <div class="card-body pt-0 p-3 p-md-4">
        <%= form_with model: @course, html: { class: "row g-3" } do |form| %>
          <div class="col-12">
            <%= render "errors/error", context: @course %>
          </div>

          <div class="col-12">
            <%= form.label :title, "Title", class: "form-label" %>
            <%= form.text_field :title, class: "form-control" %>
          </div>

          <div class="col-12">
            <%= form.label :description, "Description", class: "form-label" %>
            <%= form.text_area :description, class: "form-control", rows: 5 %>
          </div>

          <fieldset class="col-12">
            <legend class="form-label mb-2">Tier</legend>
            <div class="d-flex flex-wrap gap-3">
              <div class="form-check mb-0">
                <%= form.radio_button :tier, "free", class: "form-check-input", id: "course_tier_free" %>
                <%= form.label :tier_free, "Free", class: "form-check-label" %>
              </div>
              <div class="form-check mb-0">
                <%= form.radio_button :tier, "pro", class: "form-check-input", id: "course_tier_pro" %>
                <%= form.label :tier_pro, "Pro", class: "form-check-label" %>
              </div>
            </div>
          </fieldset>

          <div class="col-12">
            <h3 class="h6 mb-2">Lessons</h3>
            <% if @course.lessons.exists? %>
              <ol class="list-group list-group-numbered lms-course-list">
                <% @course.lessons.order(:created_at, :id).each do |lesson| %>
                  <li class="list-group-item d-flex justify-content-between align-items-center">
                    <span class="text-truncate"><%= lesson.title %></span>
                    <%= link_to "Edit", edit_course_lesson_path(@course, lesson), class: "btn btn-sm btn-outline-secondary" %>
                  </li>
                <% end %>
              </ol>
            <% else %>
              <div class="rounded-3 border border-secondary-subtle bg-light p-3">
                <p class="text-body-secondary mb-0">No lessons yet. Use Add Lesson to create your first one.</p>
              </div>
            <% end %>
          </div>

          <div class="col-12 d-flex flex-column flex-sm-row gap-2 pt-1">
            <%= form.submit "Save Changes", class: "btn btn-primary" %>
            <%= link_to "Delete Course", course_path(@course.id), data: { turbo_method: :delete, turbo_confirm: "Delete this course?" }, class: "btn btn-outline-danger" %>
          </div>
        <% end %>
      </div>
    </section>
  </div>
</div>

