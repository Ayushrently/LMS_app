<div class="app-page py-4 py-md-5">
  <div class="container">
    <section class="workspace-hero card border-0 shadow-sm mb-4">
      <div class="card-body p-3 p-md-4">
        <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
          <div>
            <p class="text-uppercase small fw-semibold text-secondary mb-1">Course Overview</p>
            <h1 class="h3 mb-1"><%= @course.title %></h1>
            <p class="text-body-secondary mb-0">Author: <span class="fw-semibold text-dark"><%= @course.creator %></span></p>
          </div>
          <div class="d-flex flex-wrap gap-2">
            <%= link_to "Back to Courses", courses_path, class: "btn btn-outline-secondary btn-sm" %>
            <% if current_user.present? %>
              <%= link_to "Profile", user_profile_path(current_user), class: "btn btn-outline-dark btn-sm" %>
              <%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete }, class: "btn btn-dark btn-sm" %>
            <% else %>
              <%= link_to "Sign in", new_user_session_path, class: "btn btn-dark btn-sm" %>
            <% end %>
          </div>
        </div>
      </div>
    </section>
    <% if current_user_author_for?(@course) %>
        <section class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white border-0 pt-3 pb-0 px-3 px-md-4">
            <h2 class="h5 mb-1">Enrollment</h2>
            <p class="text-body-secondary mb-3">Manage your enrollment in this course.</p>
        </div>
        <div class="card-body pt-0 p-3 p-md-4">
            <% if current_user.present? %>
            <% if @enrollment %>
                <p class="text-body-secondary mb-3">You are enrolled in this course.</p>
                <%= button_to "Un-enroll", course_enrollment_path(@course, @enrollment), method: :delete, class: "btn btn-outline-danger" %>
            <% else %>
                <p class="text-body-secondary mb-3">Enroll to start this course.</p>
                <%= button_to "Enroll", course_enrollments_path(@course), method: :post, class: "btn btn-primary" %>
            <% end %>
            <% else %>
            <%= link_to "Sign in to enroll", new_user_session_path, class: "btn btn-dark" %>
            <% end %>
        </div>
        </section>
    <%end%>

    <section class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white border-0 pt-3 pb-0 px-3 px-md-4">
        <h2 class="h5 mb-1">Lessons</h2>
        <p class="text-body-secondary mb-3">Browse all lessons in this course.</p>
      </div>
      <div class="card-body pt-0 p-3 p-md-4">
        <% lessons = Lesson.where(course_id: @course.id).order(:created_at, :id).pluck(:title, :id) %>
        <% if lessons.any? %>
          <ol class="list-group list-group-numbered">
            <% lessons.each do |title, id| %>
              <li class="list-group-item d-flex justify-content-between align-items-center">
                <span class="text-truncate"><%= title %></span>
                <%= link_to "Open", course_lesson_path(@course.id, id), class: "btn btn-sm btn-outline-secondary" %>
              </li>
            <% end %>
          </ol>
        <% else %>
          <div class="rounded-3 border border-secondary-subtle bg-light p-3">
            <p class="text-body-secondary mb-0">No lessons available for this course.</p>
          </div>
        <% end %>
      </div>
    </section>

    <%= render "comments/comments",
          comments: @comments,
          new_comment: @new_comment,
          comment_path: course_comments_path(@course) %>
  </div>
</div>
