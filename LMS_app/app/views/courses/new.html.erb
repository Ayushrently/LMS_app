<div class="app-page py-4 py-md-5">
  <div class="container">
    <section class="workspace-hero card border-0 shadow-sm mb-4">
      <div class="card-body p-3 p-md-4">
        <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
          <div>
            <p class="text-uppercase small fw-semibold text-secondary mb-1">Author Area</p>
            <h1 class="h3 mb-1">Create New Course</h1>
            <p class="text-body-secondary mb-0">Set up a course title, description, and tier.</p>
          </div>
          <div class="d-flex flex-wrap gap-2">
            <%= link_to "Back to Courses", courses_path, class: "btn btn-outline-secondary btn-sm" %>
            <% if current_user.present? %>
              <%= link_to "Profile", user_profile_path(current_user), class: "btn btn-outline-dark btn-sm" %>
              <%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete }, class: "btn btn-dark btn-sm" %>
            <% else %>
              <%= link_to "Sign in", new_user_session_path, class: "btn btn-dark btn-sm" %>
            <% end %>
          </div>
        </div>
      </div>
    </section>

    <section class="card border-0 shadow-sm">
      <div class="card-header bg-white border-0 pt-3 pb-0 px-3 px-md-4">
        <h2 class="h5 mb-1">Course Details</h2>
        <p class="text-body-secondary mb-3">Fill in the details below to create your course.</p>
      </div>
      <div class="card-body pt-0 p-3 p-md-4">
        <%= form_with model: @course, html: { class: "row g-3" } do |form| %>
          <div class="col-12">
            <%= render "errors/error", context: @course %>
          </div>

          <div class="col-12">
            <%= form.label :title, "Course title", class: "form-label" %>
            <%= form.text_field :title, class: "form-control" %>
          </div>

          <div class="col-12">
            <%= form.label :description, "Description", class: "form-label" %>
            <%= form.text_area :description, class: "form-control", rows: 5 %>
          </div>

          <fieldset class="col-12">
            <legend class="form-label mb-2">Course Tier</legend>
            <div class="d-flex flex-wrap gap-3">
              <div class="form-check mb-0">
                <%= form.radio_button :tier, "free", class: "form-check-input", id: "course_tier_free" %>
                <%= form.label :tier_free, "Free", class: "form-check-label" %>
              </div>
              <div class="form-check mb-0">
                <%= form.radio_button :tier, "pro", class: "form-check-input", id: "course_tier_pro" %>
                <%= form.label :tier_pro, "Pro", class: "form-check-label" %>
              </div>
            </div>
          </fieldset>

          <div class="col-12 d-flex flex-column flex-sm-row gap-2 pt-1">
            <%= form.submit "Create Course", class: "btn btn-primary" %>
            <%= link_to "Cancel", courses_path, class: "btn btn-outline-secondary" %>
          </div>
        <% end %>
      </div>
    </section>
  </div>
</div>
