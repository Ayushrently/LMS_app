<section class="workspace-hero card border-0 shadow-sm mb-4">
      <div class="card-body p-3 p-md-4">
        <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
          <div>
            <p class="text-uppercase small fw-semibold text-secondary mb-1"><%=nav_heading%></p>
            <h1 class="h3 mb-1"><%= nav_title%></h1>
            <p class="text-body-secondary mb-0"><%= nav_text %></p>
          </div>
          <div class="d-flex flex-wrap gap-2">
            <% nav_links.map do |link| %>
                <%= link_to link[:text], link[:path], class: "btn #{link[:primary] ? "btn-primary" : "btn-outline-secondary"} btn-sm" %>
            <% end %>
            <% if current_user.present? %>
              <%= (link_to "Profile", user_profile_path(current_user), class: "btn btn-outline-dark btn-sm") unless controller_name=="profiles" %>
              <%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete }, class: "btn btn-outline-dark btn-sm" %>
            <% else %>
              <%= link_to "Sign in", new_user_session_path, class: "btn btn-dark btn-sm" %>
            <% end %>
          </div>
        </div>
      </div>
    </section>