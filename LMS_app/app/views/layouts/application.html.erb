<!DOCTYPE html>
<html>
  <head>
    <title>LMSApp</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="page-<%= controller_name %>-<%= action_name %>">
    <% if flash.any? %>
      <div class="flash_stack container py-3">
        <% flash.each do |key, message| %>
          <% next if ["authors_alert", "authors_notice", "comment_error"].include?(key.to_s) %>
          <% flash_type = key.to_s == "notice" ? "success" : key.to_s == "alert" ? "danger" : "secondary" %>
          <div class="alert alert-<%= flash_type %> shadow-sm mb-2" role="alert"><%= message %></div>
        <% end %>
      </div>
    <% end %>

    <%= yield %>
  </body>
</html>
