<div class="course-workspace-page lms-course-shell py-4 py-md-5">
  <div class="container">
    <%= render "navbar/navbar",
                nav_heading: "Discussion",
                nav_title: "Edit Comment",
                nav_text: "Update your message and save changes.",
                nav_links: [
                  { text: "Back", path: request.referrer || root_path }
                ] %>

    <% comment_url = "" %>
    <% if @comment.commentable_type == "Lesson" %>
      <% course = @comment.commentable.course %>
      <% lesson = @comment.commentable %>
      <% comment_url = course_lesson_comment_path(course, lesson, @comment) %>
    <% else %>
      <% course = @comment.commentable %>
      <% comment_url = course_comment_path(course, @comment) %>
    <% end %>

    <section class="lms-comment-editor card border-0 shadow-sm">
      <div class="card-header bg-white border-0 pt-3 pb-0 px-3 px-md-4">
        <h2 class="h5 mb-1">Comment Details</h2>
        <p class="text-body-secondary mb-3">Keep feedback clear and respectful.</p>
      </div>
      <div class="card-body pt-0 p-3 p-md-4">
        <%= form_with model: @comment, url: comment_url, method: :patch, html: { class: "row g-3" } do |form| %>
          <div class="col-12">
            <%= render "errors/error", context: @comment %>
          </div>

          <div class="col-12">
            <%= form.label :body, "Comment", class: "form-label" %>
            <%= form.text_area :body, class: "form-control", rows: 5 %>
          </div>

          <div class="col-12 d-flex flex-column flex-sm-row gap-2 pt-1">
            <%= form.submit "Update Comment", class: "btn btn-primary" %>
            <%= link_to "Cancel", request.referrer || course_path, class: "btn btn-outline-secondary" %>
          </div>
        <% end %>
      </div>
    </section>
  </div>
</div>
