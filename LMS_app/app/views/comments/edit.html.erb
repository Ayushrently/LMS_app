<div class="course-workspace-page py-4 py-md-5">
  <div class="container">
    <section class="workspace-hero card border-0 shadow-sm mb-4">
      <div class="card-body p-3 p-md-4">
        <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
          <div>
            <p class="text-uppercase small fw-semibold text-secondary mb-1">Discussion</p>
            <h1 class="h3 mb-1">Edit Comment</h1>
            <p class="text-body-secondary mb-0">Update your message and save changes.</p>
          </div>
          <div class="d-flex flex-wrap gap-2">
            <%= link_to "Back", request.referrer || root_path, class: "btn btn-outline-secondary btn-sm" %>
            <% if current_user.present? %>
              <%= link_to "Profile", user_profile_path(current_user), class: "btn btn-outline-dark btn-sm" %>
              <%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete }, class: "btn btn-dark btn-sm" %>
            <% else %>
              <%= link_to "Sign in", new_user_session_path, class: "btn btn-dark btn-sm" %>
            <% end %>
          </div>
        </div>
      </div>
    </section>

    <% comment_url = "" %>
    <% if @comment.commentable_type == "Lesson" %>
      <% course = @comment.commentable.course %>
      <% lesson = @comment.commentable %>
      <% comment_url = course_lesson_comment_path(course, lesson, @comment) %>
    <% else %>
      <% course = @comment.commentable %>
      <% comment_url = course_comment_path(course, @comment) %>
    <% end %>

    <section class="card border-0 shadow-sm">
      <div class="card-header bg-white border-0 pt-3 pb-0 px-3 px-md-4">
        <h2 class="h5 mb-1">Comment Details</h2>
        <p class="text-body-secondary mb-3">Keep feedback clear and respectful.</p>
      </div>
      <div class="card-body pt-0 p-3 p-md-4">
        <%= form_with model: @comment, url: comment_url, method: :patch, html: { class: "row g-3" } do |form| %>
          <div class="col-12">
            <%= render "errors/error", context: @comment %>
          </div>

          <div class="col-12">
            <%= form.label :body, "Comment", class: "form-label" %>
            <%= form.text_area :body, class: "form-control", rows: 5 %>
          </div>

          <div class="col-12 d-flex flex-column flex-sm-row gap-2 pt-1">
            <%= form.submit "Update Comment", class: "btn btn-primary" %>
            <%= link_to "Cancel", request.referrer || course_path, class: "btn btn-outline-secondary" %>
          </div>
        <% end %>
      </div>
    </section>
  </div>
</div>
