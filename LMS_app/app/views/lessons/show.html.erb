<div class="course-workspace-page lms-course-shell py-4 py-md-5">
    <div class="container">
        <%= render "navbar/navbar",
                    nav_heading: "Lesson View",
                    nav_title: @lesson.title,
                    nav_text: "Read lesson details and join the discussion below.",
                    nav_links: [
                      { text: "Back to Course", path: course_path(@lesson.course_id) },
                      { text: "Courses", path: courses_path }
                    ] %>

        <section class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-0 pt-3 pb-0 px-3 px-md-4">
                <h2 class="h5 mb-1">Content</h2>
                <p class="text-body-secondary mb-3">Lesson material</p>
            </div>
            <div class="card-body pt-0 p-3 p-md-4">
                <p class="mb-0" style="white-space: pre-wrap;"><%= @lesson.content %></p>
            </div>
        </section>

        <%= render "comments/comments",
                    comments: @comments,
                    new_comment: @new_comment,
                    comment_path: course_lesson_comments_path(@course, @lesson) %>
    </div>
</div>