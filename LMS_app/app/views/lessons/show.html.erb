<div class="course-workspace-page py-4 py-md-5">
    <div class="container">
        <section class="workspace-hero card border-0 shadow-sm mb-4">
            <div class="card-body p-3 p-md-4">
                <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
                    <div>
                        <p class="text-uppercase small fw-semibold text-secondary mb-1">Lesson View</p>
                        <h1 class="h3 mb-1"><%= @lesson.title %></h1>
                        <p class="text-body-secondary mb-0">Read lesson details and join the discussion below.</p>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        <%= link_to "Back to Course", course_path(@lesson.course_id), class: "btn btn-outline-secondary btn-sm" %>
                        <%= link_to "Courses", courses_path, class: "btn btn-outline-secondary btn-sm" %>
                        <% if current_user.present? %>
                            <%= link_to "Profile", user_profile_path(current_user), class: "btn btn-outline-dark btn-sm" %>
                            <%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete }, class: "btn btn-dark btn-sm" %>
                        <% else %>
                            <%= link_to "Sign in", new_user_session_path, class: "btn btn-dark btn-sm" %>
                        <% end %>
                    </div>
                </div>
            </div>
        </section>

        <section class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-0 pt-3 pb-0 px-3 px-md-4">
                <h2 class="h5 mb-1">Content</h2>
                <p class="text-body-secondary mb-3">Lesson material</p>
            </div>
            <div class="card-body pt-0 p-3 p-md-4">
                <p class="mb-0" style="white-space: pre-wrap;"><%= @lesson.content %></p>
            </div>
        </section>

        <%= render "comments/comments",
                    comments: @comments,
                    new_comment: @new_comment,
                    comment_path: course_lesson_comments_path(@course, @lesson) %>
    </div>
</div>