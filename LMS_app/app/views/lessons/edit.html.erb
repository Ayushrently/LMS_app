<div class="course-workspace-page py-4 py-md-5">
    <div class="container">
        <section class="workspace-hero card border-0 shadow-sm mb-4">
            <div class="card-body p-3 p-md-4">
                <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
                    <div>
                        <p class="text-uppercase small fw-semibold text-secondary mb-1">Lesson Editor</p>
                        <h1 class="h3 mb-1">Edit Lesson</h1>
                        <p class="text-body-secondary mb-0">Update content for <span class="fw-semibold text-dark"><%= @lesson.title %></span>.</p>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        <%= link_to "Back to Lesson", course_lesson_path(@course, @lesson), class: "btn btn-outline-secondary btn-sm" %>
                        <%= link_to "Back to Course", course_path(@course), class: "btn btn-outline-secondary btn-sm" %>
                        <%= link_to "Courses", courses_path, class: "btn btn-outline-secondary btn-sm" %>
                        <% if current_user.present? %>
                            <%= link_to "Profile", user_profile_path(current_user), class: "btn btn-outline-dark btn-sm" %>
                            <%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete }, class: "btn btn-dark btn-sm" %>
                        <% else %>
                            <%= link_to "Sign in", new_user_session_path, class: "btn btn-dark btn-sm" %>
                        <% end %>
                    </div>
                </div>
            </div>
        </section>

        <section class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-3 pb-0 px-3 px-md-4">
                <h2 class="h5 mb-1">Lesson Details</h2>
                <p class="text-body-secondary mb-3">Edit title and content, then save your changes.</p>
            </div>
            <div class="card-body pt-0 p-3 p-md-4">
                <%= form_with model: [@course, @lesson], html: { class: "row g-3" } do |form| %>
                    <div class="col-12">
                        <%= render "errors/error", context: @lesson %>
                    </div>

                    <div class="col-12">
                        <%= form.label :title, "Title", class: "form-label" %>
                        <%= form.text_field :title, class: "form-control" %>
                    </div>

                    <div class="col-12">
                        <%= form.label :content, "Content", class: "form-label" %>
                        <%= form.text_area :content, class: "form-control", rows: 8 %>
                    </div>

                    <%= form.hidden_field :course_id %>

                    <div class="col-12 d-flex flex-column flex-sm-row gap-2 pt-1">
                        <%= form.submit "Update Lesson", class: "btn btn-primary" %>
                        <%= link_to "Cancel", edit_course_path(@course), class: "btn btn-outline-secondary" %>
                    </div>
                <% end %>
            </div>
        </section>
    </div>
</div>
