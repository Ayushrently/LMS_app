<div class="course-workspace-page lms-course-shell py-4 py-md-5">
    <div class="container">
        <%= render "navbar/navbar",
                    nav_heading: "Lesson Editor",
                    nav_title: "Edit Lesson",
                    nav_text: "Update content for #{@lesson.title}.",
                    nav_links: [
                      { text: "Back to Lesson", path: course_lesson_path(@course, @lesson) },
                      { text: "Back to Course", path: course_path(@course) },
                      { text: "Courses", path: courses_path }
                    ] %>

        <section class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-3 pb-0 px-3 px-md-4">
                <h2 class="h5 mb-1">Lesson Details</h2>
                <p class="text-body-secondary mb-3">Edit title and content, then save your changes.</p>
            </div>
            <div class="card-body pt-0 p-3 p-md-4">
                <%= form_with model: [@course, @lesson], html: { class: "row g-3" } do |form| %>
                    <div class="col-12">
                        <%= render "errors/error", context: @lesson %>
                    </div>

                    <div class="col-12">
                        <%= form.label :title, "Title", class: "form-label" %>
                        <%= form.text_field :title, class: "form-control" %>
                    </div>

                    <div class="col-12">
                        <%= form.label :content, "Content", class: "form-label" %>
                        <%= form.text_area :content, class: "form-control", rows: 8 %>
                    </div>

                    <%= form.hidden_field :course_id %>

                    <div class="col-12 d-flex flex-column flex-sm-row gap-2 pt-1">
                        <%= form.submit "Update Lesson", class: "btn btn-primary" %>
                        <%= link_to "Cancel", edit_course_path(@course), class: "btn btn-outline-secondary" %>
                    </div>
                <% end %>
            </div>
        </section>
    </div>
</div>
